<header class="site-header">
  <div class="header-inner">
    <a class="logo" href="<%= url_for('/') %>">
      <%= theme.brand || config.title %>
    </a>

    <div class="header-right">
      <nav class="nav-desktop" id="navDesktop">
        <% if (theme.menu) { %>
          <% for (const [label, path] of Object.entries(theme.menu)) { %>
            <a class="nav-link" href="<%= url_for(path) %>"><%= label %></a>
          <% } %>
        <% } %>
      </nav>

      <div class="header-actions">
      <% if (theme.social && theme.social.github) { %>
        <a class="header-github" href="<%= theme.social.github %>" target="_blank" rel="noopener" title="GitHub">
          <svg class="github-icon" width="20" height="20" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0 0 16 8c0-4.42-3.58-8-8-8"/></svg>
        </a>
      <% } %>
      <button class="hamburger" id="hamburgerBtn" aria-label="Toggle navigation">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
    </div>
  </div>

  <!-- 移动端导航遮罩 -->
  <div class="mobile-nav-overlay" id="mobileNavOverlay">
    <div class="mobile-nav-panel">
      <button class="mobile-nav-close" id="mobileNavClose" aria-label="Close navigation">&times;</button>
      <nav class="mobile-nav-links">
        <% if (theme.menu) { %>
          <% for (const [label, path] of Object.entries(theme.menu)) { %>
            <a class="mobile-nav-link" href="<%= url_for(path) %>"><%= label %></a>
          <% } %>
        <% } %>
        <% if (theme.social && theme.social.github) { %>
          <a class="mobile-nav-link mobile-nav-github" href="<%= theme.social.github %>" target="_blank" rel="noopener">
            <svg class="github-icon" width="18" height="18" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0 0 16 8c0-4.42-3.58-8-8-8"/></svg>
            GitHub
          </a>
        <% } %>
      </nav>
    </div>
  </div>
</header>
