<!DOCTYPE html>
<html lang="<%= config.language %>">
<head>
  <%- partial('partials/head') %>
</head>
<body>
  <%- partial('partials/header') %>

  <main class="main-content">
    <div class="container">
      <div style="text-align: center; padding: 80px 0 100px;">
        <div style="font-size: 80px; font-weight: 700; color: #d0d7de; line-height: 1; margin-bottom: 8px;">404</div>
        <p style="font-size: 18px; color: #666; margin: 12px 0 32px;">This page was not found — it may have been moved, renamed, or never existed.</p>
        <a href="<%= url_for('/') %>" style="display: inline-block; padding: 10px 28px; background: #3b82f6; color: #fff; border-radius: 6px; font-size: 15px; text-decoration: none; transition: background 0.2s;">← Back to Home</a>
      </div>
    </div>
  </main>

  <%- partial('partials/footer') %>
</body>
</html>
