<!DOCTYPE html>
<html lang="<%= config.language %>">
<head>
  <%- partial('partials/head') %>
</head>
<body>
  <%- partial('partials/header') %>

  <main class="main-content">
    <article class="post-article">
      <header class="post-header">
        <h1 class="post-title"><%= page.title %></h1>
      </header>
      <div class="post-body">
        <%- page.content %>
      </div>
    </article>
  </main>

  <%- partial('partials/footer') %>
</body>
</html>
