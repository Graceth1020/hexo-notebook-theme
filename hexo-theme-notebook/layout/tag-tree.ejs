<!DOCTYPE html>
<html lang="<%= config.language %>">
<head>
  <%- partial('partials/head') %>
  <style>
    /* 内联初始样式避免 FOUC */
    .tag-tree-list { list-style: none; padding-left: 1.5em; margin: 0; }
    .tag-tree-root { padding-left: 0; }
    .tag-tree-toggle { cursor: pointer; user-select: none; }
    .tag-tree-item { margin: 4px 0; }
    .tag-tree-label { cursor: pointer; padding: 6px 8px; border-radius: 4px; display: inline-block; }
    .tag-tree-label:hover { background: #eef2ff; }
    .tag-tree-count { color: #999; font-size: 0.85em; margin-left: 4px; }
    .tag-tree-children { display: none; }
    .tag-tree-children.expanded { display: block; }
    .tag-tree-post-item { display: flex; align-items: baseline; padding: 3px 8px 3px 1.2em; }
    .tag-tree-post-link { font-size: 0.9em; color: #3b82f6; text-decoration: none; }
    .tag-tree-post-link:hover { text-decoration: underline; }
    .tag-tree-arrow { display: inline-block; width: 16px; transition: transform 0.2s; }
    .tag-tree-arrow.expanded { transform: rotate(90deg); }
    .tag-tree-post-date { color: #999; font-size: 0.8em; margin-left: 8px; }
  </style>
</head>
<body>
  <%- partial('partials/header') %>

  <main class="main-content">
    <div class="container">
      <h1 class="page-title">Tags</h1>

      <div id="tagTreeContainer" class="tag-tree-container">
        <!-- JS 动态渲染 -->
      </div>
    </div>
  </main>

  <%- partial('partials/footer') %>
  <script src="<%= url_for('/js/tag-tree.js') %>"></script>
  <script>
    // 从 Hexo 侧透传 tag_tree 数据
    // 根据 theme.tag_tree.mode 决定数据来源:
    //   'folder'      —— 从 _posts/ 文件夹路径自动生成
    //   'frontmatter' —— 从文章 front-matter 的 tag_tree 属性读取
    <%
      var tagTreeMode = theme.tag_tree && theme.tag_tree.mode || 'folder';
      var treeMap = {};
      var directPosts = [];

      if (site.posts) {
        site.posts.toArray().forEach(function(post) {
          var treePath = null;

          if (tagTreeMode === 'frontmatter') {
            // mode: frontmatter — 使用文章 front-matter 中的 tag_tree
            if (post.tag_tree) {
              treePath = post.tag_tree;
            }
          } else {
            // mode: folder — 从 _posts/ 下的文件夹路径自动生成
            var sourcePath = (post.source || '').replace(/\\/g, '/');
            var postsPrefix = '_posts/';
            if (sourcePath.startsWith(postsPrefix)) {
              var relativePath = sourcePath.substring(postsPrefix.length);
              var lastSlash = relativePath.lastIndexOf('/');
              if (lastSlash > 0) {
                // 在子目录中：用目录路径作为 tag_tree
                treePath = relativePath.substring(0, lastSlash);
              }
              // 扁平文章（直接在 _posts/ 下）: treePath 保持 null，归入 directPosts
            }
          }

          if (treePath) {
            if (!treeMap[treePath]) {
              treeMap[treePath] = { tree: treePath, posts: [] };
            }
            treeMap[treePath].posts.push({
              title: post.title,
              path: url_for(post.path),
              date: post.date
            });
          } else {
            // 没有 tag_tree 路径的文章归入 directPosts（扁平文章）
            directPosts.push({
              title: post.title,
              path: url_for(post.path),
              date: post.date
            });
          }
        });
      }

      // 每个标签组内的文章按时间倒序排列（最新的在前）
      Object.keys(treeMap).forEach(function(key) {
        treeMap[key].posts.sort(function(a, b) {
          return b.date - a.date;
        });
      });
      // directPosts 也按时间倒序排列
      directPosts.sort(function(a, b) {
        return b.date - a.date;
      });

      var treeData = Object.keys(treeMap).map(function(key) { return treeMap[key]; });
    %>
    var TAG_TREE_DATA = <%- JSON.stringify(treeData) %>;
    var DIRECT_POSTS = <%- JSON.stringify(directPosts) %>;
    document.addEventListener('DOMContentLoaded', function() {
      renderTagTree(TAG_TREE_DATA, <%= theme.tag_tree.expand_level %>, DIRECT_POSTS);
    });
  </script>
</body>
</html>
